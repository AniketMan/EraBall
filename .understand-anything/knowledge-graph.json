      "type": "module",
      "name": "@eraball/engine",
      "filePath": "packages/engine/src/index.ts",
      "summary": "The single source of truth for all game math. A framework-free, seedable simulation engine behind a small public facade. Everything the web app and the iOS app compute goes through here — nothing is reimplemented.",
      "tags": [
        "engine",
        "facade",
        "core"
      ],
      "complexity": "complex"
    },
    {
      "id": "file:packages/engine/src/gameLogic.ts",
      "type": "file",
      "name": "gameLogic.ts",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "2,100 lines of the actual basketball math: era modifiers, positional fit penalties, player base ratings, anchors/duos/tags, proportional stat distribution, season and playoff simulation, and season awards.",
      "tags": [
        "engine",
        "simulation"
      ],
      "complexity": "complex"
    },
    {
      "id": "file:packages/engine/src/orchestrator.ts",
      "type": "file",
      "name": "orchestrator.ts",
      "filePath": "packages/engine/src/orchestrator.ts",
      "summary": "High-level entry points runGame() and rateTeam(). Composes calcTeamRating → champ-bonus simRaw → simulateSeason → simulatePlayoffs in the exact order the UI used, so any consumer can run a full game in one call.",
      "tags": [
        "engine",
        "orchestration"
      ],
      "complexity": "moderate"
    },
    {
      "id": "file:packages/engine/src/rng.ts",
      "type": "file",
      "name": "rng.ts",
      "filePath": "packages/engine/src/rng.ts",
      "summary": "A seedable random source (mulberry32). Unseeded it delegates to Math.random() (identical to production); seeded it makes a full simulation reproducible — which is what makes byte-for-byte parity testing possible.",
      "tags": [
        "engine",
        "determinism",
        "testing"
      ],
      "complexity": "simple"
    },
    {
      "id": "function:packages/engine/src/gameLogic.ts:calcTeamRating",
      "type": "function",
      "name": "calcTeamRating()",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "Turns a 9-player roster + coach + era into a team rating. Averages starter/bench adjusted ratings (70/30), then applies coach off/def bonuses and championship bonus.",
      "tags": [
        "engine",
        "rating"
      ],
      "complexity": "moderate"
    },
    {
      "id": "function:packages/engine/src/gameLogic.ts:simulateSeason",
      "type": "function",
      "name": "simulateSeason()",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "Simulates a full regular season game-by-game (72–82 games by era), then distributes each player's stats proportionally from the actual simulated team scores so the box score always adds up.",
      "tags": [
        "engine",
        "simulation"
      ],
      "complexity": "complex"
    },
    {
      "id": "function:packages/engine/src/gameLogic.ts:simulatePlayoffs",
      "type": "function",
      "name": "simulatePlayoffs()",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "Runs the best-of-7 bracket with round/seed-scaled opponents, ring-boosted win odds, special performances, and a Finals MVP. Requires 41+ regular-season wins to qualify.",
      "tags": [
        "engine",
        "playoffs"
      ],
      "complexity": "complex"
    },
    {
      "id": "function:packages/engine/src/gameLogic.ts:playerBaseRating",
      "type": "function",
      "name": "playerBaseRating()",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "The single-number player value from era-adjusted stats: PTS/REB/AST/TS%/3P plus anchor, top-75, sixth-man and duo bonuses. Feeds the salary-cap tier (S/A/B/C/D).",
      "tags": [
        "engine",
        "rating"
      ],
      "complexity": "moderate"
    },
    {
      "id": "function:packages/engine/src/gameLogic.ts:calcEraModifier",
      "type": "function",
      "name": "calcEraModifier()",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "The cross-era penalty: a player drafted outside their native decade loses effectiveness by era distance and direction (forward vs backward), with carve-outs for Timeless players and tall centers.",
      "tags": [
        "engine",
        "era"
      ],
      "complexity": "moderate"
    },
    {
      "id": "function:packages/engine/src/gameLogic.ts:calcFitPenalty",
      "type": "function",
      "name": "calcFitPenalty()",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "The positional-fit penalty: 0% at a natural slot, −10% one position off, −25% way out of position. FLEX players and position locks override the default adjacency rules.",
      "tags": [
        "engine",
        "position"
      ],
      "complexity": "moderate"
    },
    {
      "id": "concept:tag-pipeline",
      "type": "concept",
      "name": "Tag Pipeline",
      "filePath": "packages/engine/src/gameLogic.ts",
      "summary": "The ordered transform every raw player passes through before rating: withEraStats → applyFlexTag → applyRings → applySixthMan → applyFinalsMVP → applyAnchors → applyFloorGeneral → applyTimeless → applyShootingStar → applyGlassCleaner → applyDuo. Order matters and is identical on web and iOS.",
      "tags": [
        "engine",
        "tags",
        "pipeline"
      ],
      "complexity": "complex"
    },
